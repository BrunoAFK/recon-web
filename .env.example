# ── Docker Compose ─────────────────────────────────────────
# Ports exposed on the host (docker-compose.yml / docker-compose.remote.yml)
# API_PORT=3000
# WEB_PORT=8080

# Override image registry/tag for docker-compose.remote.yml
# REGISTRY=ghcr.io/brunoafk/recon-web
# TAG=latest

# ── Server ────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0

# ── API Configuration ────────────────────────────────────
# Timeout per handler in milliseconds
API_TIMEOUT_LIMIT=30000

# CORS allowlist (comma-separated). Empty/unset = CORS disabled.
API_CORS_ORIGIN=

# Global rate limit
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW=1 minute

# Maximum concurrent handlers per scan (default: 8)
# MAX_CONCURRENCY=8

# Maximum concurrent scans server-wide (default: 3)
# Extra scans queue and wait. Prevents memory exhaustion on small VMs.
# MAX_CONCURRENT_SCANS=3

# Enable Swagger API docs at /docs (default: false)
# SWAGGER_ENABLED=true

# Path to Chromium binary (auto-detected in Docker)
# CHROME_PATH=/usr/bin/chromium

# Directory for serving static frontend files (set to "none" for API-only mode)
# STATIC_DIR=

# ── Database ─────────────────────────────────────────────
# SQLite database path (auto-created)
# DB_PATH=./data/recon-web.db

# ── Scheduled Scans ─────────────────────────────────────
# Enable automated scheduled scanning
# SCHEDULE_ENABLED=true
# SCHEDULE_CRON=0 0 * * *
# SCHEDULE_URLS=https://example.com,https://another-site.com

# ── Notifications ───────────────────────────────────────
# Notification delivery method: telegram, email, or both (default: both)
# NOTIFY_METHOD=both

# Telegram notifications (requires a bot token from @BotFather)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Email notifications (SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# NOTIFY_EMAIL=alerts@example.com

# ── API Keys (optional — handlers degrade gracefully) ────
# Google Cloud API key (for PageSpeed Insights + Safe Browsing)
# GOOGLE_CLOUD_API_KEY=

# Cloudmersive API key (for malware scanning)
# CLOUDMERSIVE_API_KEY=

# BuiltWith API key (for feature detection)
# BUILT_WITH_API_KEY=

# Tranco API key (for domain ranking)
# TRANCO_API_KEY=
# TRANCO_USERNAME=

# VirusTotal API key (scan URLs against 70+ antivirus engines)
# Free: 500 req/day, 4 req/min — https://www.virustotal.com/gui/join
# VIRUSTOTAL_API_KEY=

# AbuseIPDB API key (IP reputation and abuse reports)
# Free: 1,000 req/day — https://www.abuseipdb.com/pricing
# ABUSEIPDB_API_KEY=
